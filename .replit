modules = ["nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 5000

[[ports]]
localPort = 3001
externalPort = 6000

[[ports]]
localPort = 3333
externalPort = 3000

[[ports]]
localPort = 3999
externalPort = 6800

[[ports]]
localPort = 4000
externalPort = 5173

[[ports]]
localPort = 4444
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5555
externalPort = 3002

[[ports]]
localPort = 6666
externalPort = 3003

[[ports]]
localPort = 7777
externalPort = 4200

[deployment]
deploymentTarget = "autoscale"
run = ["node", "dashboard/server.js"]
