{
  "name": "proofbridge-liner",
  "version": "1.1.1",
  "description": "Hardened Safety Kernel for Property Collateral",
  "main": "prover/main.js",
  "scripts": {
    "start": "node dashboard/server.js",
    "dev": "node dashboard/server.js",
    "fetch": "node prover/fetcher.js",
    "fetch:watch": "node prover/fetcher.js --watch",
    "submit": "node prover/submitter.js",
    "submit:dry": "node prover/submitter.js --dry-run",
    "audit": "node prover/auditor.js",
    "broadcast": "node prover/broadcaster.js",
    "broadcast:dry": "node prover/broadcaster.js --dry-run",
    "test:contracts": "/home/runner/workspace/.config/.foundry/bin/forge test -vvv",
    "deploy": "node scripts/deploy.js --target full",
    "deploy:full": "node scripts/deploy.js --target full",
    "deploy:cb": "node scripts/deploy.js --target cb",
    "deploy:simulate": "node scripts/deploy.js --target full --dry-run",
    "deploy:droplet": "bash scripts/deploy-droplet.sh",
    "deploy:droplet:rocm": "bash scripts/deploy-droplet.sh --rocm",
    "deploy:droplet:dry": "bash scripts/deploy-droplet.sh --dry-run",
    "precommit": "node scripts/check-secrets.js"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "@metamask/sdk": "^0.34.0",
    "axios": "^1.15.2",
    "ethers": "^6.16.0",
    "express": "^4.22.1",
    "opencode-ai": "^1.14.28",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^8.0.3",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@kilocode/cli": "^7.2.40",
    "husky": "^9.1.7"
  }
}
