{
  "version": 2,
  "builds": [
    {
      "src": "api/verify.js",
      "use": "@vercel/node"
    },
    {
      "src": "dashboard/public/**",
      "use": "@vercel/static"
    },
    {
      "src": "demo/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/health",     "dest": "/api/verify.js" },
    { "src": "/api/status",     "dest": "/api/verify.js" },
    { "src": "/api/verify",     "dest": "/api/verify.js", "methods": ["POST"] },
    { "src": "/api/(.*)",       "dest": "/api/verify.js" },
    { "src": "/demo/(.*)",      "dest": "/demo/$1" },
    { "src": "/(.*)",           "dest": "/dashboard/public/index.html" }
  ],
  "public": true
}
