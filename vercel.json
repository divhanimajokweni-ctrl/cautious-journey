{
  "version": 2,
  "name": "proofbridge-liner",
  "builds": [
    {
      "src": "api/verify.js",
      "use": "@vercel/node"
    },
    {
      "src": "dashboard/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/health",       "dest": "/api/verify.js" },
    { "src": "/api/status",       "dest": "/api/verify.js" },
    { "src": "/api/verify",       "dest": "/api/verify.js", "methods": ["POST"] },
    { "src": "/api/(.*)",         "dest": "/api/verify.js" },
    { "src": "/$",                "dest": "/dashboard/index.html" },
    { "src": "/(.*\\.(js|css|svg|ico|png|woff2?|json|map))", "dest": "/dashboard/public/$1" },
    { "src": "/health",           "dest": "/api/verify.js" },
    { "src": "/(.*)",             "dest": "/dashboard/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
